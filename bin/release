#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'date'

def get_current_version
  root_dir = File.expand_path('..', __dir__)
  version_rb_path = File.join(root_dir, 'lib', 'loco_motion', 'version.rb')
  File.read(version_rb_path).match(/VERSION\s*=\s*["'](.+?)["']/)[1]
end

def prompt_user(message, required: true)
  loop do
    print "#{message} "
    input = $stdin.gets.strip
    return input if !required && input.empty?
    return input unless input.empty?
    puts "WARNING: This field is required. Please enter a value."
  end
end

def prompt_yes_no(message, default: 'n')
  loop do
    print "#{message} (y/N): "
    response = $stdin.gets.strip.downcase
    response = default if response.empty?
    return response if %w[y yes n no].include?(response)
    puts "WARNING: Please enter 'y' or 'n'."
  end
end

def prompt_retry_skip_abort(message)
  loop do
    print "#{message} (r)etry / (s)kip / (a)bort: "
    response = $stdin.gets.strip.downcase
    return 'retry' if %w[r retry].include?(response)
    return 'skip' if %w[s skip].include?(response)
    return 'abort' if %w[a abort].include?(response)
    puts "WARNING: Please enter 'r', 's', or 'a'."
  end
end

def check_npm_auth
  output = `npm whoami 2>&1`.strip
  if $?.success?
    puts "SUCCESS: NPM authenticated as '#{output}'"
    true
  else
    puts "WARNING: NPM auth pre-check failed (npm whoami):"
    output.each_line { |line| puts "   #{line.rstrip}" }
    puts "   Your npm login is missing or expired. Run 'npm login' in another terminal."
    puts "   Note: 'npm publish' reports a misleading E404 for scoped packages when auth fails."
    false
  end
end

def check_gem_auth
  credentials_path = File.expand_path('~/.gem/credentials')
  if File.readable?(credentials_path)
    puts "SUCCESS: RubyGems credentials found at #{credentials_path}"
    true
  else
    puts "WARNING: RubyGems credentials not found (or not readable) at #{credentials_path}"
    puts "   Run 'gem signin' in another terminal to authenticate."
    false
  end
end

def execute_command(description, command, exit_on_failure: true)
  puts "\nEXEC: #{description}"
  puts "   Running: #{command}"

  unless system(command)
    puts "ERROR: Command failed"
    if exit_on_failure
      puts "   This step is required for the release process."
      print "   Continue anyway? (y/N): "
      response = $stdin.gets.strip.downcase
      exit unless response == 'y' || response == 'yes'
    end
    return false
  end

  puts "SUCCESS: Completed successfully"
  true
end

def check_prerequisites(dry_run: false)
  puts "CHECK: Checking release prerequisites..."
  puts

  if dry_run
    puts "DRY RUN: Running read-only prerequisite checks..."
  end

  # Check if we're on main branch (safe to run in dry run)
  current_branch = `git branch --show-current`.strip
  unless current_branch == 'main'
    puts "WARNING: You're not on the main branch (currently on: #{current_branch})"
    unless dry_run
      response = prompt_yes_no("Continue anyway?", default: 'n')
      exit unless response == 'y'
    end
  else
    puts "SUCCESS: On main branch (#{current_branch})"
  end

  # Check if there are uncommitted changes (safe to run in dry run)
  unless `git status --porcelain`.strip.empty?
    puts "WARNING: You have uncommitted changes:"
    system('git status --short')
    unless dry_run
      puts "ERROR: Please commit or stash changes before proceeding with release."
      exit 1
    end
  else
    puts "SUCCESS: No uncommitted changes"
  end

  # Warn early about missing publishing credentials so they can be fixed
  # before the release work starts. Non-fatal: publishing (step 6) re-checks
  # and offers a retry loop.
  puts "\nCHECK: Checking publishing credentials (warnings only)..."
  check_gem_auth
  check_npm_auth
  puts

  # Check if tests pass (skip in dry run as it runs commands)
  if dry_run
    puts "DRY RUN: Skipping test execution (would run 'just test')"
  else
    response = prompt_yes_no("Run tests to ensure everything is working?", default: 'y')
    if response == 'y'
      execute_command("Running all tests", "just test")
    end
  end

  if dry_run
    puts "DRY RUN: Read-only prerequisite checks completed"
  else
    puts "SUCCESS: Prerequisites check passed"
  end
end

def update_version(dry_run: false)
  puts "\nSTEP 1: Update Version"
  puts "=" * 50

  current_version = get_current_version
  puts "   Current version: #{current_version}"

  if dry_run
    puts "DRY RUN: Checking if version update is needed..."

    # Get version from main function's parsing
    version_arg = ARGV.find { |arg| !arg.start_with?('--') && !arg.start_with?('-') }

    # Check if version is already set to what we want
    if version_arg && version_arg == current_version
      puts "SUCCESS: Version already set to #{current_version}"
      return current_version
    elsif version_arg
      puts "INFO: Would update version from #{current_version} to #{version_arg}"
      return version_arg
    else
      puts "INFO: Would prompt for new version (current: #{current_version})"
      return current_version
    end
  end

  version_arg = ARGV.find { |arg| !arg.start_with?('--') && !arg.start_with?('-') }
  new_version = version_arg || prompt_user("Enter new version (e.g., 0.5.2):")

  # Check if version is already set
  if new_version == current_version
    puts "INFO: Version #{new_version} is already set"
    response = prompt_yes_no("Continue with this version?", default: 'y')
    return new_version if response == 'y'
    new_version = prompt_user("Enter different version:")
  end

  # Update version
  execute_command("Updating version to #{new_version}", "just version-set #{new_version}")

  # Update loco container
  execute_command("Updating loco container", "just loco-version-lock")

  # Show changes
  puts "\nCHANGES: Changes made:"
  system('git diff --name-only')
  puts

  response = prompt_yes_no("Commit version changes?", default: 'y')
  if response == 'y'
    execute_command("Committing version changes", "git add . && git commit -m 'Release version #{new_version}'")
  end

  new_version
end

def update_changelog(version, dry_run: false)
  puts "\nSTEP 2: Update CHANGELOG"
  puts "=" * 50

  if dry_run
    puts "DRY RUN: Checking if CHANGELOG update is needed..."

    # Check if CHANGELOG exists and has unreleased section
    if File.exist?('CHANGELOG.md')
      changelog_content = File.read('CHANGELOG.md')
      if changelog_content.include?('[Unreleased]')
        puts "INFO: CHANGELOG has [Unreleased] section that needs to be updated to [#{version}]"
      elsif changelog_content.include?("[#{version}]")
        puts "SUCCESS: CHANGELOG already has [#{version}] section"
      else
        puts "WARNING: CHANGELOG missing both [Unreleased] and [#{version}] sections"
      end
    else
      puts "WARNING: CHANGELOG.md not found"
    end
    return
  end

  # Check if CHANGELOG already has the version
  if File.exist?('CHANGELOG.md')
    changelog_content = File.read('CHANGELOG.md')
    if changelog_content.include?("[#{version}]")
      puts "INFO: CHANGELOG already has [#{version}] section"
      response = prompt_yes_no("Continue with existing CHANGELOG?", default: 'y')
      return if response == 'y'
    end
  end

  puts "   Please update CHANGELOG.md to replace '[Unreleased]' with the new version header:"
  puts "   ## [#{version}] - #{Date.today.strftime('%Y-%m-%d')}"
  puts

  response = prompt_yes_no("Open CHANGELOG.md for editing?", default: 'y')
  if response == 'y'
    system("#{ENV['EDITOR'] || 'nano'} CHANGELOG.md")
  end

  response = prompt_yes_no("Commit CHANGELOG changes?", default: 'y')
  if response == 'y'
    execute_command("Committing CHANGELOG", "git add CHANGELOG.md && git commit -m 'docs: Finalize CHANGELOG for release v#{version}'")
  end
end

def generate_llms_docs(version, dry_run: false)
  puts "\nSTEP 2.5: Generate LLM Documentation"
  puts "=" * 50

  if dry_run
    puts "DRY RUN: Would generate llms.txt documentation"
    puts "   Running: just llm"
    return
  end

  response = prompt_yes_no("Generate llms.txt documentation?", default: 'y')
  if response == 'y'
    execute_command("Generating llms.txt", "just llm")

    response = prompt_yes_no("Commit llms.txt changes?", default: 'y')
    if response == 'y'
      # `just llm` writes the files into docs/demo/public/ (llms.txt,
      # llms-full.txt, and versioned copies). It also boots the demo
      # container, which can refresh docs/demo/Gemfile.lock, so include it.
      execute_command("Committing llms.txt", "git add docs/demo/public/llms*.txt docs/demo/Gemfile.lock && git commit -m 'docs: Update llms.txt for release v#{version}'")
    end
  else
    puts "INFO: Skipping llms.txt generation (you can run it later with 'just llm')"
  end
end

def build_packages(dry_run: false)
  puts "\nSTEP 3: Build Packages"
  puts "=" * 50

  version = get_current_version
  gem_path = "builds/rubygems/loco_motion-rails-#{version}.gem"
  npm_path = "builds/npm/profoundry-us-loco_motion-#{version}.tgz"

  if dry_run
    puts "DRY RUN: Checking if packages need to be built..."

    # Check if packages already exist
    gem_exists = File.exist?(gem_path)
    npm_exists = File.exist?(npm_path)

    if gem_exists && npm_exists
      puts "SUCCESS: Both packages already built:"
      puts "   - Ruby gem: #{gem_path}"
      puts "   - NPM package: #{npm_path}"
    elsif gem_exists
      puts "INFO: Ruby gem exists, NPM package missing:"
      puts "   - Ruby gem: #{gem_path} (exists)"
      puts "   - NPM package: #{npm_path} (would build)"
    elsif npm_exists
      puts "INFO: NPM package exists, Ruby gem missing:"
      puts "   - Ruby gem: #{gem_path} (would build)"
      puts "   - NPM package: #{npm_path} (exists)"
    else
      puts "INFO: Both packages need to be built:"
      puts "   - Ruby gem: #{gem_path} (would build)"
      puts "   - NPM package: #{npm_path} (would build)"
    end
    return
  end

  # Check if packages already exist
  gem_exists = File.exist?(gem_path)
  npm_exists = File.exist?(npm_path)

  if gem_exists && npm_exists
    puts "INFO: Both packages already exist:"
    puts "   - Ruby gem: #{gem_path}"
    puts "   - NPM package: #{npm_path}"
    response = prompt_yes_no("Rebuild packages anyway?", default: 'n')
    return if response != 'y'
  end

  # Build Ruby gem if needed
  unless gem_exists
    execute_command("Building Ruby gem", "just gem-build")
  else
    puts "INFO: Ruby gem already exists: #{gem_path}"
  end

  # Verify gem exists
  unless File.exist?(gem_path)
    puts "ERROR: Ruby gem not found at expected location: #{gem_path}"
    exit 1
  end

  # Build NPM package if needed
  unless npm_exists
    execute_command("Building NPM package", "just npm-build")
  else
    puts "INFO: NPM package already exists: #{npm_path}"
  end

  # Verify NPM package exists
  unless File.exist?(npm_path)
    puts "ERROR: NPM package not found at expected location: #{npm_path}"
    exit 1
  end

  puts "\nSUCCESS: Both packages built successfully!"
  response = prompt_yes_no("Continue with publishing?", default: 'y')
  exit unless response == 'y'
end

def create_and_merge_pr(dry_run: false)
  puts "\nSTEP 4: Create and Merge PR"
  puts "=" * 50

  current_branch = `git branch --show-current`.strip

  if dry_run
    if current_branch == 'main'
      puts "DRY RUN: On main - would push origin main directly (no PR needed)"
    else
      puts "DRY RUN: On feature branch '#{current_branch}' - would push it, prompt"
      puts "   to open/merge a PR, then check out and pull main"
    end
    return
  end

  if current_branch == 'main'
    # Releases run directly on main: the push lands the commits, so there is no
    # PR to open or merge - just push and confirm success.
    response = prompt_yes_no("Push release commits to main?", default: 'y')
    if response == 'y'
      execute_command("Pushing changes to origin/main", "git push origin main")
      puts "SUCCESS: Release commits pushed to main."
    end
  else
    # Releasing from a feature branch: push that branch and gate on the PR merge.
    response = prompt_yes_no("Push changes and create PR?", default: 'y')
    if response == 'y'
      execute_command("Pushing changes to origin", "git push origin #{current_branch}")

      puts "\nINFO: Please create a pull request with your changes:"
      puts "   1. Go to: https://github.com/profoundry-us/loco_motion/compare/main...#{current_branch}"
      puts "   2. Create pull request"
      puts "   3. Get it reviewed and approved"
      puts "   4. Merge it to main"

      response = prompt_yes_no("Have you merged the PR to main?", default: 'n')
      unless response == 'y'
        puts "WARNING: Please merge the PR before continuing."
        exit 1
      end

      execute_command("Pulling latest changes from main", "git checkout main && git pull origin main")
    end
  end
end

def tag_release(version, dry_run: false)
  puts "\nSTEP 5: Tag Release"
  puts "=" * 50

  # Helper function to check tag existence
  def check_tag_status(version)
    # Check local tag (fast)
    local_tag_exists = system("git rev-parse --verify --quiet refs/tags/v#{version} > /dev/null 2>&1")

    # Check remote tag (only if needed, use faster method)
    remote_tag_exists = false
    if local_tag_exists
      # Faster remote check - just see if the tag exists in the remote refs
      remote_tag_exists = system("git ls-remote --exit-code origin refs/tags/v#{version} > /dev/null 2>&1")
    end

    [local_tag_exists, remote_tag_exists]
  end

  local_tag_exists, remote_tag_exists = check_tag_status(version)

  if dry_run
    puts "DRY RUN: Checking if git tag exists..."

    if local_tag_exists && remote_tag_exists
      puts "SUCCESS: Tag v#{version} exists locally and remotely"
    elsif local_tag_exists
      puts "INFO: Tag v#{version} exists locally but not remotely (would push)"
    elsif remote_tag_exists
      puts "INFO: Tag v#{version} exists remotely but not locally (would pull)"
    else
      puts "INFO: Tag v#{version} does not exist (would create and push)"
    end
    return
  end

  if local_tag_exists && remote_tag_exists
    puts "INFO: Tag v#{version} already exists locally and remotely"
    response = prompt_yes_no("Create new tag anyway?", default: 'n')
    return if response != 'y'
  elsif local_tag_exists
    puts "INFO: Tag v#{version} exists locally but not remotely"
    response = prompt_yes_no("Push existing tag to remote?", default: 'y')
    if response == 'y'
      execute_command("Pushing tag to origin", "git push origin v#{version}")
    end
    return
  elsif remote_tag_exists
    puts "INFO: Tag v#{version} exists remotely but not locally"
    response = prompt_yes_no("Pull remote tag locally?", default: 'y')
    if response == 'y'
      execute_command("Pulling remote tag", "git fetch origin tag v#{version}")
    end
    return
  end

  # Create and push new tag
  execute_command("Creating git tag", "git tag v#{version}")
  execute_command("Pushing tag to origin", "git push origin v#{version}")
end

def publish_with_retries(name, command, auth_check:, fix_hint:)
  loop do
    failure = nil

    if send(auth_check)
      if execute_command("Publishing #{name}", command, exit_on_failure: false)
        return true
      end
      puts "   #{fix_hint}"
      failure = "publish failed"
    else
      failure = "auth pre-check failed"
    end

    puts
    case prompt_retry_skip_abort("#{name}: #{failure}. Fix credentials in another terminal, then:")
    when 'retry'
      next
    when 'skip'
      puts "INFO: Skipping #{name} publishing."
      return false
    when 'abort'
      puts "WARNING: Aborting release. Resolve publishing issues and re-run bin/release."
      exit 1
    end
  end
end

def publish_packages(dry_run: false)
  puts "\nSTEP 6: Publish Packages"
  puts "=" * 50

  if dry_run
    puts "DRY RUN: Skipping package publishing"
    puts "   Would run an auth pre-check before each publish:"
    puts "   - RubyGems: verify ~/.gem/credentials exists ('gem signin' to fix)"
    puts "   - NPM: run 'npm whoami' ('npm login' to fix)"
    puts "   Would publish:"
    puts "   - Ruby gem to RubyGems.org"
    puts "   - NPM package to npmjs.com"
    puts "   On a failed pre-check or publish, would prompt Retry / Skip / Abort"
    puts "   so credentials can be fixed without restarting the wizard."
    return
  end

  puts "   This step requires your credentials for both RubyGems and NPM."
  puts "   Each publish runs an auth pre-check first. If a pre-check or a"
  puts "   publish fails, you can fix your credentials in another terminal"
  puts "   and retry without restarting the wizard."
  puts

  # Publish Ruby gem
  gem_published = false
  puts "INFO: Publishing Ruby Gem to RubyGems.org..."
  response = prompt_yes_no("Continue with gem publishing?", default: 'y')
  if response == 'y'
    gem_published = publish_with_retries(
      "Ruby gem", "just gem-publish",
      auth_check: :check_gem_auth,
      fix_hint: "If this is an auth problem, run 'gem signin' in another terminal."
    )
    puts "   Verify at: https://rubygems.org/gems/loco_motion-rails" if gem_published
  end

  # Publish NPM package
  npm_published = false
  puts "\nINFO: Publishing NPM package to npmjs.com..."
  response = prompt_yes_no("Continue with NPM publishing?", default: 'y')
  if response == 'y'
    npm_published = publish_with_retries(
      "NPM package", "just npm-publish",
      auth_check: :check_npm_auth,
      fix_hint: "An E404 here usually means expired auth ('npm whoami' to check, 'npm login' to fix)."
    )
    puts "   Verify at: https://www.npmjs.com/package/@profoundry-us/loco_motion" if npm_published
  end

  unless gem_published && npm_published
    skipped = []
    skipped << "Ruby gem ('just gem-publish')" unless gem_published
    skipped << "NPM package ('just npm-publish')" unless npm_published
    puts "\nWARNING: Not published: #{skipped.join(', ')}."
    puts "   You can publish manually later with the commands above."
    response = prompt_yes_no("Continue with the rest of the release anyway?", default: 'n')
    exit 1 unless response == 'y'
  end
end

def create_github_release(version, dry_run: false)
  puts "\nSTEP 7: Create GitHub Release"
  puts "=" * 50

  if dry_run
    puts "DRY RUN: Skipping GitHub release creation"
    puts "   Would create release at: https://github.com/profoundry-us/loco_motion/releases/new"
    puts "   With tag: v#{version}"
    return
  end

  puts "   Please create a GitHub release:"
  puts "   1. Go to: https://github.com/profoundry-us/loco_motion/releases/new"
  puts "   2. Select tag: v#{version}"
  puts "   3. Add release notes (GitHub AI can help)"
  puts "   4. Publish the release"
  puts

  response = prompt_yes_no("Have you created the GitHub release?", default: 'n')
  unless response == 'y'
    puts "WARNING: Please create the GitHub release before continuing."
    exit 1
  end
end

def update_demo_app(dry_run: false)
  puts "\nSTEP 8: Update Demo App"
  puts "=" * 50

  if dry_run
    puts "DRY RUN: Skipping demo app update"
    puts "   Would run: bin/update_demo_after_release"
    return
  end

  puts "   This will run the post-release script to update the demo app."
  response = prompt_yes_no("Continue with demo app update?", default: 'y')

  if response == 'y'
    execute_command("Updating demo app", "bin/update_demo_after_release")
  end
end

def main
  puts "RELEASE: LocoMotion Release Wizard"
  puts "=" * 50
  puts "   This wizard will walk you through the complete release process."
  puts

  # Parse arguments
  dry_run = ARGV.include?('--dry-run')

  # Show help if requested
  if ARGV.include?('--help') || ARGV.include?('-h')
    puts <<~HELP
      Usage: bin/release [VERSION] [OPTIONS]

      This wizard walks you through the complete LocoMotion release process:
      1. Check prerequisites
      2. Update version
      3. Update CHANGELOG
      4. Build packages
      5. Create and merge PR
      6. Tag release
      7. Publish packages (requires credentials)
      8. Create GitHub release
      9. Update demo app

      Options:
        VERSION        Optional: Skip version prompt and use this version
        --dry-run      Run in dry run mode (skips git state checks and actual commands)
        --help         Show this help message

      Dry Run Mode:
        - Skips git state checks (main branch, uncommitted changes)
        - Shows what would be done without executing commands
        - Useful for testing the release workflow

      Prerequisites:
        - Clean git state (unless in dry run mode)
        - RubyGems.org credentials
        - NPM credentials
        - GitHub access for creating releases
    HELP
    exit 0
  end

  if dry_run
    puts "DRY RUN: No actual commands will be executed"
    puts
  end

  begin
    check_prerequisites(dry_run: dry_run)

    version = update_version(dry_run: dry_run)
    update_changelog(version, dry_run: dry_run)
    generate_llms_docs(version, dry_run: dry_run)
    build_packages(dry_run: dry_run)
    create_and_merge_pr(dry_run: dry_run)
    tag_release(version, dry_run: dry_run)
    publish_packages(dry_run: dry_run)
    create_github_release(version, dry_run: dry_run)
    update_demo_app(dry_run: dry_run)

    if dry_run
      puts "\nDRY RUN COMPLETED"
      puts "   No actual changes were made."
      puts "   Run without --dry-run to execute the release."
    else
      puts "\nSUCCESS: Release v#{version} completed successfully!"
      puts "=" * 50
      puts "   What's next:"
      puts "   1. Monitor demo app deployment"
      puts "   2. Verify Algolia indexing"
      puts "   3. Test the demo site"
    end

  rescue Interrupt
    puts "\n\nWARNING: Release process interrupted by user"
    exit 1
  rescue => e
    puts "\nERROR: #{e.message}"
    exit 1
  end
end

main
