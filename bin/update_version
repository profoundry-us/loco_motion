#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'fileutils'

# Gem-style pre-release versions use a dot before the suffix (0.8.0.pre), but
# npm requires semver's hyphen form (0.8.0-pre). Convert only the first
# dot-before-a-letter so numeric suffix parts stay dotted (0.8.0.pre.1 ->
# 0.8.0-pre.1).
def npm_version(version)
  version.sub(/\.(?=[a-z])/i, '-')
end

def prerelease?(version)
  version.match?(/[a-z]/i)
end

def update_version(new_version = nil)
  root_dir = File.expand_path('../..', __FILE__)
  version_rb_path = File.join(root_dir, 'lib', 'loco_motion', 'version.rb')

  # Get current version if no new version provided
  current_version = File.read(version_rb_path).match(/VERSION\s*=\s*["'](.+?)["']/)[1]

  if new_version.nil?
    puts "Current version: #{current_version}"
    print "Enter new version (or press enter to cancel): "
    new_version = gets.strip
    exit if new_version.empty?
  end

  # Validate version format: x.y.z releases, plus gem-style pre-releases
  # (x.y.z.pre, x.y.z.alpha.1) used to mark main as unreleased between tags.
  unless new_version.match?(/^\d+\.\d+\.\d+(\.[a-z]+(\.\d+)?)?$/i)
    puts "Error: Version must be x.y.z or x.y.z.pre (e.g., 1.0.0, 1.1.0.pre)"
    exit 1
  end

  begin
    # Update version.rb
    version_dir = File.join(root_dir, 'lib', 'loco_motion')
    FileUtils.mkdir_p(version_dir)

    version_content = <<~RUBY
      # frozen_string_literal: true

      module LocoMotion
        VERSION = "#{new_version}"
      end
    RUBY
    File.write(version_rb_path, version_content)
    puts "✓ Updated version.rb"

    # Update VERSION file (required by custom Heroku buildpack)
    version_file_path = File.join(root_dir, 'VERSION')
    File.write(version_file_path, new_version)
    puts "✓ Updated VERSION file"

    # Update package.json (npm requires the hyphenated semver pre-release form)
    package_json_path = File.join(root_dir, 'package.json')
    if File.exist?(package_json_path)
      package_json = JSON.parse(File.read(package_json_path))
      package_json['version'] = npm_version(new_version)
      File.write(package_json_path, JSON.pretty_generate(package_json) + "\n")
      puts "✓ Updated package.json"
    end

    # The demo dependency pin and the documented install pins must always point
    # at a *published* version, so a pre-release bump leaves them at the last
    # release rather than pointing installs at a version no registry serves.
    if prerelease?(new_version)
      puts "ℹ️  Pre-release version: leaving docs/demo/package.json and install pins at the last release"
    else
      # Update docs/demo/package.json
      demo_package_json_path = File.join(root_dir, 'docs', 'demo', 'package.json')
      if File.exist?(demo_package_json_path)
        demo_package_json = JSON.parse(File.read(demo_package_json_path))
        if demo_package_json['dependencies'] && demo_package_json['dependencies']['@profoundry-us/loco_motion']
          demo_package_json['dependencies']['@profoundry-us/loco_motion'] = "^#{new_version}"
          File.write(demo_package_json_path, JSON.pretty_generate(demo_package_json) + "\n")
          puts "✓ Updated docs/demo/package.json"
        end
      end
    end

    # Update the documented `gem "loco_motion-rails", "~> X.Y.Z"` install pins
    # so the README and Install guide track the released version. A stale pin
    # silently excludes the new release (e.g. "~> 0.5.2" excludes 0.6.0), so
    # new installs following the docs resolve to the previous minor series.
    # The Install guide's numeric prefix shifts when the docs section is
    # reordered (a hardcoded 02_install path silently broke when it became
    # 03_install), so resolve it by glob and complain when nothing matches.
    unless prerelease?(new_version)
      install_docs = Dir.glob('docs/demo/app/views/docs/*_install.html.haml', base: root_dir).sort
      if install_docs.empty?
        puts "⚠️  No install guide matched docs/demo/app/views/docs/*_install.html.haml — install pin NOT updated!"
      end

      install_pin_files = ['README.md', *install_docs]
      install_pin_files.each do |rel_path|
        path = File.join(root_dir, rel_path)
        unless File.exist?(path)
          puts "⚠️  Install pin file missing (skipping): #{rel_path}"
          next
        end

        # Read/write as UTF-8 explicitly: these docs contain non-ASCII bytes
        # (em dashes, emoji), and a US-ASCII default external encoding would
        # otherwise raise "invalid byte sequence" on the gsub.
        content = File.read(path, encoding: 'UTF-8')
        updated = content.gsub(
          /(gem\s+["']loco_motion-rails["'],\s*["']~>\s*)\d+\.\d+\.\d+/,
          "\\1#{new_version}"
        )
        next if updated == content

        File.write(path, updated, encoding: 'UTF-8')
        puts "✓ Updated install pin in #{rel_path}"
      end
    end

    puts "\nSuccessfully updated version to #{new_version}"
    puts "\n📋 Next steps for release:"
    puts "1. Review the changes: git diff"
    puts "2. Update loco container: just loco-version-lock"
    puts "3. Build and test packages: just gem-build && just npm-build"
    puts "4. Update CHANGELOG.md with release notes"
    puts "5. Commit the changes: git commit -am 'Release version #{new_version}'"
    puts "6. Push to main, tag, and publish packages"
    puts "7. After publishing, update demo app: bin/update_demo_after_release"
    puts
    puts "ℹ️  Tip: bin/release is an interactive wizard that walks through all"
    puts "   of these steps (plus llms.txt regeneration) for you. The demo app"
    puts "   is updated after package publication to avoid circular dependencies."

  rescue StandardError => e
    puts "Error updating version: #{e.message}"
    exit 1
  end
end

if ARGV.empty?
  update_version
else
  update_version(ARGV[0])
end
