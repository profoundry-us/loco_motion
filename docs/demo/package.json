{
  "name": "app",
  "private": true,
  "engines": {
    "node": "~20 || ~22",
    "yarn": "~1.22"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@profoundry-us/loco_motion": "^0.6.0",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "algoliasearch": "^5.55.2",
    "autoprefixer": "^10.5.4",
    "cally": "^0.9.2",
    "daisyui": "^5.6.18",
    "esbuild": "^0.28.1",
    "instantsearch.js": "^4.106.0",
    "tailwindcss": "^4.3.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "./node_modules/.bin/tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css",
    "build:production": "NODE_ENV=production npm run build && npm run build:css --minify"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1"
  }
}
