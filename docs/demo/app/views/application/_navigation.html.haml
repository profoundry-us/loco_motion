- icons = { docs: "book-open", guides: "document-text", loco: "sparkles", daisy: "square-3-stack-3d" }

%turbo-frame#navmenu{ target: "content", "data-nav-target": "menu" }
  %ul.menu.w-full.px-4.py-0{ class: "mt-2.5" }
    - @nav_sections.each do |section|
      %li
        %h2.menu-title.text-lg.text-base-content.flex.flex-row.items-center.gap-1.tracking-wide
          = loco_icon(section[:icon], css: "text-#{section[:icon_color]}")
          = section[:title]

        %ul.ml-5
          - new_badge_css = ["badge-secondary badge-xs ml-auto transition-all",
            "group-hover:-rotate-3 group-hover:scale-125",
            "group-focus:-rotate-3 group-focus:scale-125"]
          - section[:items].each do |item|
            - if item[:is_group]
              %li
                .menu-title.text-primary.font-bold.tracking-wide
                  = item[:title].upcase
                %ul.ml-4
                  - item[:items].each do |subitem|
                    %li
                      = link_to subitem[:path],
                        class: request.original_url.include?(subitem[:path]) ? "group menu-active" : "group",
                        data: { action: "click->nav#refresh", "turbo-action": "replace" } do
                        = subitem[:title]
                        - # aria-hidden keeps link accessible names stable (the
                        - # badge is a visual affordance, not part of the name).
                        - if subitem[:new]
                          = daisy_badge("New", css: new_badge_css, html: { "aria-hidden": "true" })
            - else
              %li
                = link_to item[:path],
                  class: (request.original_url == root_url && item[:path] == root_path) || request.original_url.include?(item[:path]) ? "group menu-active" : "group",
                  data: { action: "click->nav#refresh", "turbo-action": "replace" } do
                  = item[:title]
                  - if item[:new]
                    = daisy_badge("New", css: new_badge_css, html: { "aria-hidden": "true" })

    .mt-8.pt-10.pb-12.border-t.border-base-300.text-center.text-xs
      <em>That's all folks!</em> 😉
