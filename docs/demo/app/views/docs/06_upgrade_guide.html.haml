      %span{ class: "text-2xl" }= emoji
      %span{ class: "font-bold" }= name
      %p{ class: "text-sm text-base-content/70" }= description

.mt-12.prose
  %h2{ id: "checklist", class: "scroll-mt-24" } Upgrade checklist

.max-w-prose.mt-6.flex.flex-col.gap-4
  = daisy_checkbox(name: "upgrade_packages", id: "upgrade_packages") do |checkbox|
    - checkbox.with_trailing do
      :markdown
        Bump `loco_motion-rails` to `~> 0.7.0`, the npm package to
        `0.7.0`, and DaisyUI to 5.6+ (now a declared peer dependency).
  = daisy_checkbox(name: "upgrade_rename", id: "upgrade_rename") do |checkbox|
    - checkbox.with_trailing do
      :markdown
        Run `bin/rails loco_motion:migrate:leading_trailing` (dry-run,
        then `APPLY=1`) and review the diff.
  = daisy_checkbox(name: "upgrade_icons", id: "upgrade_icons") do |checkbox|
    - checkbox.with_trailing do
      :markdown
        Sync your icons and rename `hero_icon` to `loco_icon` — see the
        [icon migration guide](#{doc_path("migrating_icons")}).
  = daisy_checkbox(name: "upgrade_forms", id: "upgrade_forms") do |checkbox|
    - checkbox.with_trailing do
      :markdown
        Check forms that post checkboxes / toggles for the new
        hidden-field behavior (`include_hidden: false` opts out).

%p{ class: "mt-4 max-w-prose text-sm text-base-content/60" }
  These are real
  %code daisy_checkbox
  components — and per step 4, unchecking one would now submit a
  %code 0
  😉

