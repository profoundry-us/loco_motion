= content_for(:page_title) do
  Home

- # The landing page renders full-width (no sidenav) — see the layout's
- # `hide_sidenav` handling. Its scroll choreography (hero cluster parallax +
- # pop-in flair) is driven by the `parallax` Stimulus controller declared on
- # the root. Every piece of decorative flair is a REAL, interactive LocoMotion
- # component wrapped in `doc_flair`, so the homepage dogfoods the library, and
- # everything uses DaisyUI semantic tokens so it adapts to all six themes.
- content_for(:hide_sidenav, true)

- guides = [["🚀", "Getting Started", "getting_started", "The LocoMotion philosophy, and how to choose your path into the guides."], ["🐳", "Docker", "docker", "A consistent, reliable development environment for any OS."], ["🛤️", "Rails Setup", "rails_setup", "Stand up a new Rails app with HAML, TailwindCSS, and DaisyUI."], ["📝", "HAML", "haml", "Cleaner, indentation-based templates for a better developer experience."], ["🧩", "Building Components", "building_components", "Build your own ViewComponents with the LocoMotion DSL — parts, slots, and Stimulus.", true], ["🐛", "Debugging & Testing", "debugging", "ruby-debug, RSpec, and Playwright for a fast feedback loop."], ["⚙️", "Service Objects", "services", "Keep business logic clean and testable with ActiveInteraction."], ["🔒", "Authentication", "authentication", "Wire up OmniAuth sign-in with the developer strategy."], ["⚠️", "Error Handling", "error_handling", "Inspect errors in the browser with Web Console and BetterErrors."]]
- # The guide count comes from the nav (built from the files on disk) so the
- # stat stays correct as guides are added.
- guide_count = @nav_sections.find { |section| section[:title] == "Guides" }[:items].count
- # The ∞ glyph renders far shorter than digits at the same font size, so it
- # takes a larger size with the 3xl line height to keep the row rhythm.
- stats = [["70+", "Ready-made components", "text-primary"], [guide_count, "Guides", "text-secondary"], ["∞", "Themeable", "text-accent", "text-5xl leading-9"], ["100%", "Ruby on Rails", "text-base-content"]]

%div{ class: "relative", "data-ads-target": "hidden", "data-controller": "parallax flair" }
  - # ============================================================ HERO
  %div{ class: "relative overflow-visible rounded-3xl bg-linear-to-b from-primary/5 via-base-100 to-base-100 px-6 py-24 text-center md:py-32" }
    - # ---- Hero cluster: real, interactive components that drift on scroll ----
    = doc_flair(pos: "top-11 left-[7%]", rot: -7, speed: 0.55, drift: -0.22) do
      = daisy_chat(css: "chat-start") do |chat|
        - chat.with_avatar(wrapper_css: "bg-primary/15 text-lg") do
          🚂
        - chat.with_bubble(css: "border border-base-300 bg-base-100 font-semibold shadow-lg") do
          choo choo!

    = doc_flair(pos: "top-9 right-[9%]", rot: 6, speed: 0.85, drift: 0.14) do
      = daisy_toggle(name: "hero_toggle", id: "hero_toggle", checked: true, css: "toggle-primary shadow-lg")

    = doc_flair(pos: "top-[46%] left-[4%]", rot: 4, speed: 0.35, drift: -0.34) do
      = daisy_rating(name: "hero_rating", id: "hero_rating", value: 4, inputs_css: "bg-warning", css: "drop-shadow-md")

    = doc_flair(pos: "top-[42%] right-[4%]", rot: -5, speed: 0.65, drift: 0.3) do
      = daisy_badge("New!", css: "badge-secondary badge-lg font-bold shadow-lg cursor-pointer select-none", action: "click->flair#shake")

    = doc_flair(pos: "bottom-[70px] left-[9%]", rot: 5, speed: 0.5, drift: -0.16) do
      %span{ class: "inline-flex gap-1 cursor-pointer", data: { action: "click->flair#openSearch" } }
        = daisy_kbd("⌘")
        = daisy_kbd("K")

    = doc_flair(pos: "bottom-[88px] right-[11%]", rot: -4, speed: 0.95, drift: 0.36) do
      - # Scrubs to the pointer on click or drag. The 200ms fill transition is
      - # quick enough to chase a drag; `touch-none` keeps touch scrubs from
      - # scrolling the page.
      = daisy_progress(value: 70, max: 100, css: "progress-info w-32 shadow-lg cursor-pointer touch-none [&::-webkit-progress-value]:[transition:width_200ms_ease-out] [&::-moz-progress-bar]:[transition:width_200ms_ease-out]", html: { data: { action: "pointerdown->flair#startScrub pointermove->flair#moveScrub pointerup->flair#endScrub pointercancel->flair#endScrub" } })

    = doc_flair(pos: "top-[16%] right-[22%]", rot: 6, speed: 0.72, drift: 0.2) do
      = daisy_radial(value: 70, css: "text-accent bg-base-100 text-xs font-bold shadow-lg cursor-pointer", html: { data: { action: "click->flair#randomizeRadial" } }) do
        70%

    = doc_flair(pos: "top-[14%] left-[20%]", rot: -6, speed: 0.42, drift: -0.26) do
      = daisy_button("+", css: "btn-secondary btn-circle text-xl shadow-lg", action: "click->flair#poof")

    = doc_flair(pos: "bottom-[34px] left-[38%]", rot: -3, show: "lg", speed: 0.6, drift: 0.1) do
      = daisy_chat(css: "chat-start") do |chat|
        - chat.with_avatar(wrapper_css: "bg-secondary/15 text-base") do
          💬
        - chat.with_bubble(css: "border border-base-300 bg-base-100 font-semibold shadow-lg") do
          daisy_chat, obviously

    - # ---- Headline ----
    - # The headline column sits above the hero flair (z-10). It ignores pointer
    - # events so clicks land on the interactive flair behind it; its own text
    - # and buttons opt back in with `pointer-events-auto`.
    %div{ class: "pointer-events-none relative z-10 mx-auto flex max-w-4xl flex-col items-center gap-6" }
      - # Solid badges — the soft style colors its text with the raw token,
      - # which goes invisible on retro/wireframe; solid uses the token PAIR.
      %div{ class: "flex flex-wrap justify-center gap-2" }
        = daisy_badge("ViewComponent", css: "badge-primary font-bold")
        = daisy_badge("DaisyUI", css: "badge-secondary font-bold")
        = daisy_badge("TailwindCSS", css: "badge-accent font-bold")

      %h1{ class: "pointer-events-auto text-4xl font-black leading-tight tracking-tight text-balance md:text-5xl lg:text-6xl" }
        Components, Guides, and Paradigms for
        - # Gradient-filled text can't be made readable in every theme (retro's
        - # pastels fail against its cream base even mixed with base-content),
        - # so the word stays base-content and the gradient becomes a marker
        - # bar behind its baseline. The rotate transform also scopes the -z bar
        - # to the em's own stacking context.
        %em{ class: "relative inline-block -rotate-2 transition-transform hover:scale-110 hover:-rotate-6" }
          %span{ class: "absolute -inset-x-[0.1em] bottom-[0.02em] -z-10 h-[0.32em] rounded-full bg-linear-to-r from-primary to-secondary", aria: { hidden: true } }
          CRAZY-fast
        Development in Ruby on Rails!

      %div{ class: "pointer-events-auto flex flex-col items-center gap-4 sm:flex-row" }
        - # The library's own Aura (new in 0.7) replaces the static shadow —
        - # its light renders in currentColor, tinted secondary so it reads as
        - # a distinct glow rather than a blur of the primary button.
        = daisy_aura(css: "aura-dual text-secondary") do
          = daisy_button "📦 Install Guide", css: "btn-primary btn-lg text-lg", right_icon: "arrow-right", href: doc_path("install"), turbo_frame: "_top", turbo_action: "advance", action: "click->nav#refresh"
        - # `before:hidden` drops the mockup's dots header so it reads as a
        - # one-line prompt sized to sit beside the CTA button. The gem name is
        - # a bg/text token PAIR — the only DaisyUI construct that stays
        - # readable on the neutral chip in every theme; plain accent colors go
        - # invisible in wireframe (secondary == neutral there).
        = daisy_code(prefix: "$", css: "w-fit min-w-0 py-3 before:hidden") do
          bundle add #{content_tag(:span, "loco_motion-rails", class: "rounded bg-secondary px-1.5 py-0.5 text-secondary-content")}

      - # The flair components this line teases are `hidden md:block` (see
      - # DocFlairComponent), so the hint hides below `md` right along with them.
      %div{ class: "hidden text-xs text-base-content/50 md:block" } scroll — watch the components leave the station ↓

  - # ============================================================ LIVE PREVIEW
  %div{ class: "relative z-10 -mt-8 flex justify-center px-2 pb-4" }
    %div{ class: "flex w-full max-w-2xl flex-col gap-4" }
      - # The chrome tint comes from the browser itself; the content pane sits
      - # on base-100 so the toolbar reads as part of the window, not a strip.
      = daisy_browser(css: "border border-base-300 bg-base-200 shadow-2xl") do |browser|
        - browser.with_toolbar do
          %span{ class: "font-mono text-xs text-base-content/50" } live preview
        %div{ class: "flex flex-wrap items-center justify-center gap-6 bg-base-100 px-6 py-9" }
          = daisy_button("Accent Button", css: "btn-accent")
          = daisy_tip("Click to Swap") do
            = daisy_swap(off: "🌚", on: "🌞", css: "swap-rotate text-3xl")
          = daisy_badge("Large Badge", css: "badge-secondary badge-lg")

      = doc_code(language: "haml") do
        :plain
          = daisy_button "Accent Button", css: "btn-accent"
          = daisy_tip("Click to Swap") do
            = daisy_swap off: "🌚", on: "🌞"
          = daisy_badge "Large Badge", css: "badge-secondary badge-lg"

      %div{ class: "flex justify-center" }
        = daisy_button "See All Components", css: "btn-secondary btn-soft", right_icon: "arrow-right", href: doc_path("components"), turbo_frame: "_top", turbo_action: "advance", action: "click->nav#refresh"

  - # ============================================================ STATS
  %div{ class: "grid grid-cols-2 gap-px border-y border-base-300 bg-base-300 md:grid-cols-4" }
    - stats.each do |number, label, color, size|
      = daisy_stat(css: "place-items-center bg-base-100", value_css: "#{size || 'text-3xl'} font-black #{color}", description_css: "text-base-content/60", description: label) do
        = number

  - # ============================================================ FEATURE: HAML
  %div{ class: "relative mx-auto flex max-w-6xl flex-col items-center gap-10 px-4 py-24 lg:flex-row" }
    = doc_flair(pos: "top-6 -left-2", rot: -6, show: "md", pop: true) do
      = daisy_chat(css: "chat-start") do |chat|
        - chat.with_avatar(wrapper_css: "bg-accent/15 text-base") do
          💎
        - chat.with_bubble(css: "border border-base-300 bg-base-100 font-semibold shadow-lg") do
          so much cleaner

    = doc_flair(pos: "bottom-8 -right-[14px]", rot: 8, show: "md", pop: true) do
      = daisy_loading(css: "loading-spinner loading-lg text-primary")

    %div{ class: "flex flex-1 flex-col gap-4" }
      %div{ class: "text-xs font-bold tracking-[.1em] text-secondary" } SIMPLE, CONCISE VIEWS
      %h3{ class: "text-3xl font-black tracking-tight" } No more messy ERB.
      %p{ class: "text-base-content/70 leading-relaxed" }
        Utilize
        = daisy_link("HAML", "https://haml.info/", target: "_blank")
        so your views are simple, concise, and easy to understand. HAML feels
        more natural to write and reduces file sizes, making your views easier
        to read and maintain.
      %p{ class: "text-base-content/70 leading-relaxed" }
        %strong PLUS!
        You can utilize filters like
        %em Markdown
        \, CoffeeScript, Textile, and many more!
      = daisy_button "Read the HAML guide", css: "btn-secondary btn-soft btn-sm w-fit", right_icon: "arrow-right", href: guide_path("haml"), turbo_frame: "_top", turbo_action: "advance", action: "click->nav#refresh"

    %div{ class: "grid w-full flex-1 gap-4 sm:grid-cols-2" }
      %div
        %div{ class: "mb-2 font-mono text-xs font-bold tracking-wide text-error" } ERB · 12 LINES 😵
        = doc_code(language: "erb") do
          :plain
            <% 5.times do |i| %>
              <% if i.even? %>
                <p class="odd">
                  Number <%= i %>
                </p>
              <% else %>
                <p class="even">
                  Numero <%= i %>
                </p>
              <% end %>
            <% end %>
      %div
        %div{ class: "mb-2 font-mono text-xs font-bold tracking-wide text-success" } HAML · 5 LINES ✨
        = doc_code(language: "haml") do
          :plain
            - 5.times do |i|
              - if i.even?
                %p.odd Number \#{i}
              - else
                %p.even Numero \#{i}

  - # ==================================================== FEATURE: BUILD YOUR OWN
  %div{ class: "relative mx-auto flex max-w-6xl flex-col gap-10 px-4 pb-24 lg:flex-row-reverse lg:items-center" }
    = doc_flair(pos: "-top-7 right-6", rot: 5, show: "md", pop: true) do
      = daisy_badge("define_parts :head, :body, :legs", css: "badge-neutral badge-lg font-mono shadow-lg")

    %div{ class: "flex flex-1 flex-col gap-4" }
      %div{ class: "text-xs font-bold tracking-[.1em] text-accent" } POWERFUL DSL
      %h3{ class: "text-3xl font-black tracking-tight" }
        Build your
        %em OWN
        components.
      %p{ class: "text-base-content/70 leading-relaxed" }
        Can't find exactly what you need? No problem! Build your own components
        with ease using our simple, flexible, and powerful DSL — parts, tags,
        CSS, and Stimulus controllers, all in one place.
      = daisy_button "Read the components guide", css: "btn-accent btn-soft btn-sm w-fit", right_icon: "arrow-right", href: guide_path("building_components"), turbo_frame: "_top", turbo_action: "advance", action: "click->nav#refresh"

    %div{ class: "w-full flex-1" }
      = doc_code(language: "ruby") do
        :plain
          # app/components/character_component.rb
          class CharacterComponent < ApplicationComponent
            define_parts :head, :body, :legs

            def before_render
              set_tag_name(:head, :h1)
              add_css(:head, "text-3xl font-bold")
              add_stimulus_controller(:body, "character-body")
            end
          end

  - # ============================================================ GUIDES
  %div{ class: "relative border-t border-base-300 bg-base-200 px-4 py-24" }
    = doc_flair(pos: "top-10 left-[26px]", rot: -4, show: "md", pop: true) do
      = daisy_badge("✅ New guide published!", css: "badge-lg border-base-300 bg-base-100 font-semibold shadow-xl")

    = doc_flair(pos: "bottom-14 right-[30px]", rot: 6, show: "lg", pop: true) do
      %div{ class: "avatar-group -space-x-3" }
        = daisy_avatar(css: "border-2", wrapper_css: "w-9 bg-primary/15 text-xs font-black text-primary") do
          RB
        = daisy_avatar(css: "border-2", wrapper_css: "w-9 bg-secondary/15 text-xs font-black text-secondary") do
          JS
        = daisy_avatar(css: "border-2", wrapper_css: "w-9 bg-accent/15 text-xs font-black text-accent") do
          UI

    %div{ class: "mx-auto max-w-6xl" }
      %div{ class: "mb-8 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between" }
        %h3{ class: "text-3xl font-black tracking-tight" } Guides &amp; Paradigms
        %span{ class: "text-sm text-base-content/60" } The LocoMotion way of building Rails apps.

      %div{ class: "grid gap-4 sm:grid-cols-2 lg:grid-cols-3" }
        - guides.each do |emoji, name, filename, description, is_new|
          = daisy_card(css: "relative bg-base-100 border border-base-300 transition hover:-translate-y-1 hover:shadow-xl", href: guide_path(filename), turbo_frame: "_top", turbo_action: "advance", action: "click->nav#refresh") do
            - if is_new
              = daisy_badge("New", css: "badge-accent badge-sm absolute right-3 top-3")
            %span{ class: "text-3xl" }= emoji
            %span{ class: "text-lg font-bold" }= name
            %p{ class: "text-sm text-base-content/70" }= description

        = daisy_card(css: "bg-primary text-primary-content sm:col-span-2", body_css: "sm:flex-row sm:items-center sm:justify-between gap-4") do
          %div{ class: "flex flex-col gap-1" }
            %span{ class: "text-lg font-black" } More coming soon!
            %span{ class: "text-sm opacity-85" } More components, guides, and suggested gems on the way.
          - # Secondary here too — distinct from both the white button and the
          - # primary card behind it.
          = daisy_aura(css: "aura-dual text-secondary") do
            = daisy_button "😉 Get Started", css: "btn-lg border-none bg-base-100 text-primary hover:scale-105", right_icon: "arrow-right", href: guide_path("getting_started"), turbo_frame: "_top", turbo_action: "advance", action: "click->nav#refresh"
