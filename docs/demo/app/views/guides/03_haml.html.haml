.prose
  :markdown
    # Haml Templates

    HAML (HTML Abstraction Markup Language) simplifies your HTML templates with
    a cleaner, more concise syntax that emphasizes indentation over closing tags
    and brackets. It's designed to make template creation more enjoyable and
    maintainable.

- # The roadmap: five sections plus the victory lap. The links opt out of
- # Turbo because the layout wraps pages in a turbo-frame, which would
- # otherwise swallow same-page anchor jumps.
.mt-8.rounded-box.border.border-base-300.p-6
  = daisy_steps(css: "w-full steps-vertical sm:steps-horizontal") do |steps|
    - steps.with_step(css: "step-primary") do
      %a{ href: "#why", class: "link-hover", data: { turbo: "false" } } Why HAML
    - steps.with_step(css: "step-primary") do
      %a{ href: "#install", class: "link-hover", data: { turbo: "false" } } Install
    - steps.with_step(css: "step-primary") do
